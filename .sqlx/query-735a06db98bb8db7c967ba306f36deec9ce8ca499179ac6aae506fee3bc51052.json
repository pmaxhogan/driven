  "query": "\n                SELECT\n                    source_id     AS \"source_id!: String\",\n                    relative_path AS \"relative_path!: String\",\n                    size          AS \"size!: i64\",\n                    status        AS \"status!: String\",\n                    drive_file_id AS \"drive_file_id: String\"\n                FROM file_state\n                WHERE source_id = ?1\n                  AND (\n                    relative_path = ?2\n                    OR (relative_path >= ?3 AND relative_path < ?4)\n                  )\n                ORDER BY relative_path ASC\n                LIMIT ?5\n                ",
